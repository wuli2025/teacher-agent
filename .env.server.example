# 教师助手 服务器部署环境变量。复制为 .env 后填写：
#   cp .env.server.example .env
# （根目录已有的 .env.example 是桌面/旧模板，服务器部署以本文件为准）

# ── 与 polaris-app 的隔离（同机并存时才需要动）──
# 容器名/卷名已固定为 teacher-*，不会撞。这三个是宿主侧资源，按需错开：
TEACHER_IMAGE_TAG=latest
TEACHER_WEB_PORT=8081          # polaris-app 用 8080，这里默认 8081
# TEACHER_RELAY_PORT=8443      # relay 默认占 443；polaris-app 也起 relay 时改这个

# ── 访问口令（公网部署必填！仅通过 HTTPS 域名首次传入）──
POLARIS_AUTH_TOKEN=

# Web 端口默认只监听宿主机 loopback，公网请由 Caddy/Nginx/Traefik 以 HTTPS 反代。
# 仅可信内网调试才改为 0.0.0.0（此时流量仍是明文）。
POLARIS_BIND_IP=127.0.0.1

# 协作项目只允许绑定此受控目录内已经存在的本地 Git 仓库（容器内路径）。
POLARIS_REPO_ROOT=/home/polaris/Polaris/repos

# ── 接入 LLM（三选一）──
# A. Claude 官方 API Key
ANTHROPIC_API_KEY=

# B. 第三方 Anthropic 兼容端点（智谱/Kimi/DeepSeek/聚合站等）：
#    填 BASE_URL + AUTH_TOKEN，留空 ANTHROPIC_API_KEY
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=

# C. Claude 订阅 OAuth：容器起来后进 App「供应商」面板登录，无需在此填写

# ── Gitea 管理员（初始化协作 git 托管时用，见 DEPLOY-CLOUD.md）──
GITEA_ADMIN_USER=polaris-admin
GITEA_ADMIN_PASSWORD=
GITEA_ADMIN_EMAIL=admin@example.com
